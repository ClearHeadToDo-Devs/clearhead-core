	<https://clearhead.us/vocab/actions/v4#hasUUID> "019e513a-db99-70c0-8f33-24e20e239d0f" ;
	<http://www.w3.org/2000/01/rdf-schema#label> "strip source from domain Action" ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "remove source: Option<SourceMetadata> from domain/mod.rs Action struct — file position is not a domain concern" ;
