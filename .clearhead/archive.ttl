	<https://clearhead.us/vocab/actions/v4#hasUUID> "019e513a-db99-7ce7-987e-fed03998d32a" ;
	<http://www.w3.org/2000/01/rdf-schema#label> "extend SourcedAction to carry source range" ;
	<http://www.w3.org/2000/01/rdf-schema#comment> "add range: Option<SourceRange> to SourcedAction — absorbs what Action.source was holding for LSP diagnostics" ;
